# Twilio Account Credentials
# Used for SMS notifications, voice calls, and 2FA
# DO NOT COMMIT — production secrets

# Twilio Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Twilio Auth Token (keep secret — used to sign API requests)
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Twilio phone numbers
TWILIO_PHONE_NUMBER_SMS=+15005550006
TWILIO_PHONE_NUMBER_VOICE=+15005550007

# Messaging Service SID (for sending to multiple numbers)
TWILIO_MESSAGING_SERVICE_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Verify Service SID (for OTP / 2FA flows)
TWILIO_VERIFY_SERVICE_SID=VAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# API Key + Secret (alternative auth — scoped credentials)
TWILIO_API_KEY=SKXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook signing secret (validates incoming Twilio webhooks)
TWILIO_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: subaccount for billing isolation
TWILIO_SUBACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
