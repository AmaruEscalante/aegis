# Discord Webhook Configuration
# Used by CI/CD pipeline to post deployment and alert notifications
# DO NOT COMMIT — contains webhook secrets

# General deployments channel
DISCORD_WEBHOOK_DEPLOY=https://discord.com/api/webhooks/XXXXXXXXXXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Alerts / on-call channel
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/XXXXXXXXXXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Engineering team announcements
DISCORD_WEBHOOK_ANNOUNCEMENTS=https://discord.com/api/webhooks/XXXXXXXXXXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Bot token for interactive bot commands (read/reply to messages)
DISCORD_BOT_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Application (client) ID
DISCORD_CLIENT_ID=XXXXXXXXXXXXXXXXXXX

# Guild (server) ID for slash command registration
DISCORD_GUILD_ID=XXXXXXXXXXXXXXXXXXX

# Notification settings
DISCORD_NOTIFY_ON_SUCCESS=true
DISCORD_NOTIFY_ON_FAILURE=true
DISCORD_MENTION_ROLE_ON_FAILURE=XXXXXXXXXXXXXXXXXXX
