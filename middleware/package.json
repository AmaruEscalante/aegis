{
  "name": "dataguard",
  "version": "1.0.0",
  "description": "OpenClaw plugin for local-only PII sanitization and file-access guardrails",
  "main": "dist/plugin/index.js",
  "openclaw": {
    "extensions": ["dist/plugin/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "mammoth": "^1.7.1",
    "minimatch": "^9.0.5",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pdfkit": "^0.17.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "security",
    "pii",
    "sanitization",
    "data-protection"
  ],
  "author": "",
  "license": "MIT"
}
