{
  "name": "aegis-gate",
  "version": "1.1.0",
  "description": "On-device privacy gate for AI agents — MCP plugin",
  "main": "dist/mcp-server.js",
  "bin": {
    "aegis-gate": "dist/cli.js"
  },
  "files": [
    "dist/",
    "aegis/",
    "skills/",
    "scripts/",
    "docs/PRIVACY.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "mcp": "node dist/mcp-server.js",
    "mcp:dev": "npx tsx src/mcp-server.ts",
    "prepack": "npm run build && bash ../scripts/copy-package-assets.sh",
    "postpack": "bash ../scripts/clean-package-assets.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "mammoth": "^1.7.1",
    "minimatch": "^9.0.5",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.4.168",
    "shell-quote": "^1.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/shell-quote": "^1.7.5",
    "pdfkit": "^0.17.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "mcp",
    "privacy",
    "ai-safety",
    "claude-code",
    "on-device"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmaruEscalante/aegis.git"
  }
}
